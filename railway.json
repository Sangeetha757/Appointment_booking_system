{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE"
    },
    "deploy": {
        "startCommand": "docker-entrypoint.sh",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "releaseCommand": "php artisan migrate --seed --force"
    }
}